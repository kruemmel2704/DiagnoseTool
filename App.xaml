<Application x:Class="DiagnoseTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        
        <!-- Palette Colors -->
        <Color x:Key="ColorBgMain">#0F111A</Color>
        <Color x:Key="ColorBgSidebar">#08090E</Color>
        <Color x:Key="ColorBgCard">#161923</Color>
        <Color x:Key="ColorBgCardHover">#1E2230</Color>
        
        <Color x:Key="ColorAccentCyan">#00E5FF</Color>
        <Color x:Key="ColorAccentPurple">#A855F7</Color>
        
        <Color x:Key="ColorTextPrimary">#F3F4F6</Color>
        <Color x:Key="ColorTextSecondary">#9CA3AF</Color>
        <Color x:Key="ColorTextMuted">#4B5563</Color>
        
        <Color x:Key="ColorSuccess">#10B981</Color>
        <Color x:Key="ColorWarning">#F59E0B</Color>
        <Color x:Key="ColorDanger">#EF4444</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="BrushBgMain" Color="{StaticResource ColorBgMain}" />
        <SolidColorBrush x:Key="BrushBgSidebar" Color="{StaticResource ColorBgSidebar}" />
        <SolidColorBrush x:Key="BrushBgCard" Color="{StaticResource ColorBgCard}" />
        <SolidColorBrush x:Key="BrushBgCardHover" Color="{StaticResource ColorBgCardHover}" />
        
        <SolidColorBrush x:Key="BrushAccentCyan" Color="{StaticResource ColorAccentCyan}" />
        <SolidColorBrush x:Key="BrushAccentPurple" Color="{StaticResource ColorAccentPurple}" />
        
        <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
        <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
        <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}" />

        <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
        <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}" />
        <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />

        <!-- Gaps and Shadows -->
        <DropShadowEffect x:Key="ShadowCard" BlurRadius="15" Color="#000000" Opacity="0.3" ShadowDepth="3" />
        <DropShadowEffect x:Key="ShadowGlowCyan" BlurRadius="12" Color="{StaticResource ColorAccentCyan}" Opacity="0.5" ShadowDepth="0" />
        <DropShadowEffect x:Key="ShadowGlowPurple" BlurRadius="12" Color="{StaticResource ColorAccentPurple}" Opacity="0.5" ShadowDepth="0" />

        <!-- Base Typography -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Inter, Roboto, sans-serif" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        </Style>

        <Style x:Key="TextHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        </Style>

        <Style x:Key="TextSubheader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        </Style>

        <Style x:Key="TextMuted" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
        </Style>

        <!-- Rounded Cards -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Effect" Value="{StaticResource ShadowCard}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#222636" />
        </Style>

        <!-- Modern Round Buttons -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1D2436" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#313952" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                CornerRadius="8" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#2A344D" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushAccentCyan}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#151A29" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushAccentCyan}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button (Glowing Accent) -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource BrushAccentCyan}" />
            <Setter Property="Foreground" Value="#08090E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                CornerRadius="8" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#40EFFF" />
                                <Setter TargetName="border" Property="Effect" Value="{StaticResource ShadowGlowCyan}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#00C4DB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Navigation Buttons -->
        <Style x:Key="SidebarButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="GroupName" Value="Navigation" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="bgBorder" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="true" Margin="4,2"/>
                            <!-- Active indicator bar -->
                            <Border x:Name="indicator" HorizontalAlignment="Left" Width="4" Height="20" Background="{StaticResource BrushAccentCyan}" CornerRadius="2" Visibility="Hidden" Margin="8,0,0,0"/>
                            
                            <ContentPresenter x:Name="contentPresenter" 
                                              ContentTemplate="{TemplateBinding ContentTemplate}" 
                                              Content="{TemplateBinding Content}" 
                                              ContentStringFormat="{TemplateBinding ContentStringFormat}" 
                                              HorizontalAlignment="Left" 
                                              VerticalAlignment="Center" 
                                              Margin="24,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="bgBorder" Property="Background" Value="#1A1C24" />
                                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="bgBorder" Property="Background" Value="#161923" />
                                <Setter TargetName="indicator" Property="Visibility" Value="Visible" />
                                <Setter Property="Foreground" Value="{StaticResource BrushAccentCyan}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat Custom Progress Bar Style -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#10131E" />
            <Setter Property="Foreground" Value="{StaticResource BrushAccentCyan}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border CornerRadius="3" Background="{TemplateBinding Background}" />
                            <Border x:Name="PART_Indicator" CornerRadius="3" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
