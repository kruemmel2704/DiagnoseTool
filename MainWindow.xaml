<Window x:Class="DiagnoseTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiagnoseTool"
        mc:Ignorable="d"
        Title="Hardware Diagnostics &amp; Testing Tool" 
        Height="680" Width="1050"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="12" Background="{StaticResource BrushBgMain}" BorderBrush="#252A3C" BorderThickness="1.5" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar Column -->
                <ColumnDefinition Width="230" />
                <!-- Main Content Column -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ================= SIDEBAR ================= -->
            <Border Grid.Column="0" Background="{StaticResource BrushBgSidebar}" BorderBrush="#1C1E27" BorderThickness="0,0,1.5,0">
                <Grid Margin="12,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Logo -->
                        <RowDefinition Height="Auto" /> <!-- Spacer -->
                        <RowDefinition Height="*" />    <!-- Navigation -->
                        <RowDefinition Height="Auto" /> <!-- USB / Status Area -->
                        <RowDefinition Height="Auto" /> <!-- Footer Clock -->
                    </Grid.RowDefinitions>

                    <!-- Logo / Branding (Official CPM Vector Logo) -->
                    <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,20">
                        <Viewbox Width="120" Height="43" HorizontalAlignment="Center">
                            <Canvas Width="119.11" Height="42.75">
                                <!-- Top part of C -->
                                <Path Fill="{StaticResource BrushTextPrimary}" Data="M16.68,11c.23-.45,.58-.84,1-1.12,.38-.3,.86-.46,1.34-.45l15.71,.17L37.36,.24,16.38,0c-1.68-.04-3.33,.39-4.77,1.26-1.46,.9-2.73,2.06-3.76,3.43-1.14,1.52-2.09,3.17-2.83,4.92-.82,1.85-1.53,3.74-2.14,5.66,.01,.06,.01,.11,0,.17l11.76,.14c.6-1.56,1.28-3.09,2.04-4.58Z"/>
                                <!-- Bottom part of C -->
                                <Path Fill="{StaticResource BrushAccentCyan}" Data="M13.16,32.09c-.47-.12-.89-.38-1.21-.75-.32-.37-.46-.86-.38-1.34,.31-2.93,.9-5.81,1.75-8.63,.36-1.15,.76-2.27,1.19-3.38l-11.75-.11c-.58,1.87-1.07,3.73-1.46,5.56-.38,1.83-.74,3.56-1,5C.05,29.85-.05,31.29,.02,32.72c.06,1.44,.33,2.86,.81,4.21,.42,1.26,1.13,2.4,2.07,3.34,.98,.97,2.27,1.58,3.65,1.73,6.58,.88,13.25,.8,19.8-.24l2.67-9.76c-2.59,.53-5.23,.79-7.87,.78-2.66-.02-5.32-.26-7.94-.71l-.05,.02Z"/>
                                <!-- Top part of P -->
                                <Path Fill="{StaticResource BrushTextPrimary}" Data="M50.93,7.64l6.6,.07c.42,0,.83,.13,1.18,.36,.36,.24,.66,.54,.9,.9,.25,.38,.44,.79,.57,1.23,.13,.42,.2,.87,.2,1.31,0,1.19-.21,2.37-.63,3.49-.15,.4-.33,.79-.54,1.16l10.07,.12c0-.17,.12-.34,.17-.51,.55-1.98,.85-4.02,.88-6.08,.01-1.04-.15-2.07-.48-3.05-.31-.96-.8-1.86-1.44-2.64-1-1.16-2.27-2.04-3.71-2.56-1.41-.51-2.89-.78-4.38-.8l-18-.2-4.4,15.42,10.59,.14,2.42-8.36Z"/>
                                <!-- Bottom part of P -->
                                <Path Fill="{StaticResource BrushAccentCyan}" Data="M59.2,18.53c-.33,.62-.72,1.21-1.18,1.75-.29,.34-.57,.67-.84,1-.29,.33-.63,.61-1,.84-.46,.26-.95,.45-1.46,.56-.72,.14-1.46,.2-2.19,.18l-5.31-.06,1.29-4.42-10.59-.12-6.76,23.59,10.59,.15,3.21-11.12,12.25,.12c1.03,.02,2.06-.19,3-.62,.95-.42,1.84-.96,2.65-1.62,.85-.69,1.62-1.48,2.3-2.34,.67-.86,1.29-1.76,1.86-2.7,.94-1.6,1.69-3.3,2.23-5.07l-10.05-.12Z"/>
                                <!-- Bottom M left -->
                                <Path Fill="{StaticResource BrushAccentCyan}" Data="M67.7,42.28l10.5,.12,6.7-23.57-10.5-.13-6.7,23.58Z"/>
                                <!-- Bottom M center -->
                                <Path Fill="{StaticResource BrushAccentCyan}" Data="M88.92,34h2.31l11.46-15-16.23-.19,2.46,15.19Z"/>
                                <!-- Bottom M right -->
                                <Path Fill="{StaticResource BrushAccentCyan}" Data="M104.15,19.05l-6.77,23.57,10.64,.13,6.68-23.58-10.55-.12Z"/>
                                <!-- Top part of M -->
                                <Path Fill="{StaticResource BrushTextPrimary}" Data="M119.11,1.33l-9.55-.11c-1.26,0-2.49,.31-3.59,.92-1.18,.65-2.2,1.54-3,2.63l-6.95,9.37-1.43-9c-.11-.6-.34-1.18-.68-1.69-.66-1-1.62-1.76-2.75-2.16-.55-.19-1.13-.29-1.71-.29l-10.64-.14-4.39,15.43,10.5,.12,1-3.53,.57,3.56,16.23,.19,2.32-3-.87,3.07,10.56,.12,4.38-15.49Z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="DIAGNOSE TOOL" FontSize="11" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Separator Grid.Row="1" Background="#1C1F2E" Margin="4,0,4,20"/>

                    <!-- Navigation Buttons -->
                    <StackPanel Grid.Row="2">
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Content="Dashboard" 
                                     IsChecked="{Binding IsDashboardSelected, Mode=OneWay}"
                                     Command="{Binding SelectTabCommand}" 
                                     CommandParameter="0" />
                                     
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Content="Testing Tools" 
                                     IsChecked="{Binding IsToolsSelected, Mode=OneWay}"
                                     Command="{Binding SelectTabCommand}" 
                                     CommandParameter="1" 
                                     Margin="0,8,0,0" />
                                     
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Content="System Repair" 
                                     IsChecked="{Binding IsRepairSelected, Mode=OneWay}"
                                     Command="{Binding SelectTabCommand}" 
                                     CommandParameter="2" 
                                     Margin="0,8,0,0" />

                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Content="Batterie-Test" 
                                     IsChecked="{Binding IsBatteryTestSelected, Mode=OneWay}"
                                     Command="{Binding SelectTabCommand}" 
                                     CommandParameter="4" 
                                     Margin="0,8,0,0" />
                                     
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Content="System Guide" 
                                     IsChecked="{Binding IsInfoSelected, Mode=OneWay}"
                                     Command="{Binding SelectTabCommand}" 
                                     CommandParameter="3" 
                                     Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- USB Detection Widget -->
                    <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="12" Margin="4,0,4,16" Background="#0C0E14" BorderBrush="#1C1F2E">
                        <StackPanel>
                            <TextBlock Text="USB DRIVES SCANNER" FontSize="10" FontWeight="Bold" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>
                            <Button Style="{StaticResource ModernButton}" 
                                    Content="Scan Removable Drives" 
                                    Command="{Binding RefreshUsbCommand}" 
                                    FontSize="11" 
                                    Padding="8,6" 
                                    HorizontalAlignment="Stretch"/>
                            <TextBlock Text="Press to check for USB tools" FontSize="9" Foreground="{StaticResource BrushTextSecondary}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Sidebar Footer Clock -->
                    <StackPanel Grid.Row="4" Margin="4,0,4,6">
                        <TextBlock Text="{Binding CurrentTime}" 
                                   HorizontalAlignment="Center" 
                                   FontSize="11" 
                                   FontWeight="Medium" 
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <TextBlock Text="v1.0.0 | Admin Privileges Active" 
                                   HorizontalAlignment="Center" 
                                   FontSize="9" 
                                   Foreground="{StaticResource BrushSuccess}" 
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= MAIN CONTENT ================= -->
            <Grid Grid.Column="1" Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header Bar -->
                    <RowDefinition Height="*" />    <!-- Content Pages -->
                    <RowDefinition Height="Auto" /> <!-- Status Bar -->
                </Grid.RowDefinitions>

                <!-- Header Bar (Title & Window Controls) -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="Hardware Diagnostics &amp; Benchmarks" Style="{StaticResource TextHeader}"/>
                        <TextBlock Text="Real-time monitoring and fast execution of USB stress-testing utilities." Style="{StaticResource TextSubheader}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Minimize / Close Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,-6,0,0">
                        <Button Click="MinimizeButton_Click" 
                                Width="32" Height="32" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand"
                                Foreground="{StaticResource BrushTextSecondary}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1C2130"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Path Data="M 6 15 L 18 15 Z" Stroke="{StaticResource BrushTextPrimary}" StrokeThickness="2" Width="12" Height="12" Stretch="Fill"/>
                        </Button>

                        <Button Click="CloseButton_Click" 
                                Width="32" Height="32" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand"
                                Foreground="{StaticResource BrushTextSecondary}"
                                Margin="6,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrushDanger}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Path Data="M 6 6 L 18 18 M 6 18 L 18 6" Stroke="{StaticResource BrushTextPrimary}" StrokeThickness="2" Width="10" Height="10" Stretch="Fill"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ================= PAGES CONTAINER ================= -->
                <Grid Grid.Row="1">
                    
                    <!-- PAGE 0: DASHBOARD -->
                    <Grid Visibility="{Binding IsDashboardSelected, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <!-- General Stats Panel -->
                            <ColumnDefinition Width="360" />
                            <!-- Cores Temperature Grid -->
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- General Diagnostics (CPU, GPU, RAM) -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                            <StackPanel>
                                
                                <!-- Werte-Aufzeichnung (PDF-Report) Card -->
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="MESSWERTE-AUFZEICHNUNG" FontWeight="Bold" Foreground="{StaticResource BrushAccentCyan}" FontSize="11" Margin="0,0,0,10"/>
                                        
                                        <!-- Active Recording Indicator -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Pulsing Red Dot (Only visible when IsRecording is true) -->
                                            <Ellipse x:Name="recordingDot" Width="10" Height="10" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0" 
                                                     Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard x:Name="PulsingDot">
                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.2" Duration="0:0:0.8"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="PulsingDot"/>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Bereit zur Aufnahme" />
                                                        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                                <Setter Property="Text" Value="Aufzeichnung läuft..." />
                                                                <Setter Property="Foreground" Value="#EF4444" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>

                                        <!-- Stats Details -->
                                        <Grid Margin="0,0,0,12" Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Messdauer" Style="{StaticResource TextMuted}"/>
                                                <TextBlock Text="{Binding RecordingTimeDisplay}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Datenpunkte" Style="{StaticResource TextMuted}"/>
                                                <TextBlock Text="{Binding RecordedSamplesCount}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Start/Stop Buttons -->
                                        <Grid>
                                            <!-- Start button (Visible when NOT recording) -->
                                            <Button Style="{StaticResource PrimaryButton}" 
                                                    Content="Aufzeichnung starten" 
                                                    Command="{Binding StartRecordingCommand}" 
                                                    Height="36"
                                                    Visibility="{Binding IsNotRecording, Converter={StaticResource BoolToVis}}"/>
                                            
                                            <!-- Stop button (Visible when recording) -->
                                            <Button Style="{StaticResource PrimaryButton}" 
                                                    Background="#EF4444"
                                                    Content="Stoppen &amp; PDF erstellen" 
                                                    Command="{Binding StopRecordingCommand}" 
                                                    Height="36"
                                                    Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                <Setter TargetName="border" Property="Background" Value="#F87171" />
                                                                <Setter TargetName="border" Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect BlurRadius="12" Color="#EF4444" Opacity="0.5" ShadowDepth="0" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="true">
                                                                <Setter TargetName="border" Property="Background" Value="#DC2626" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- CPU Overview Card -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="CPU SUMMARY" FontWeight="Bold" Foreground="{StaticResource BrushAccentCyan}" FontSize="12"/>
                                            <TextBlock Text="{Binding Diagnostics.CpuClockDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>
                                        </Grid>
                                        
                                        <!-- CPU Usage -->
                                        <TextBlock Text="Processor Load" FontSize="11" Foreground="{StaticResource BrushTextSecondary}" Margin="0,12,0,4"/>
                                        <Grid>
                                            <ProgressBar Style="{StaticResource ModernProgressBar}" Value="{Binding Diagnostics.CpuAverageLoad}" Maximum="100"/>
                                        </Grid>
                                        <Grid Margin="0,4,0,12">
                                            <TextBlock Text="Overall Usage" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding Diagnostics.CpuAverageLoad, StringFormat={}{0:F1} %}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12"/>
                                        </Grid>

                                        <!-- CPU Temp -->
                                        <TextBlock Text="Package Temperature" FontSize="11" Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,4"/>
                                        <Grid>
                                            <ProgressBar Style="{StaticResource ModernProgressBar}" Value="{Binding Diagnostics.CpuAverageTemp}" Maximum="100" Foreground="{StaticResource BrushWarning}"/>
                                        </Grid>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="Overall Temp" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding Diagnostics.CpuAverageTemp, StringFormat={}{0:F1} °C}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- GPU Overview Card -->
                                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="GPU BENCHMARK DATA" FontWeight="Bold" Foreground="{StaticResource BrushAccentPurple}" FontSize="12" Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding Diagnostics.GpuName}" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}" FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,0,0,10"/>

                                        <!-- GPU Load -->
                                        <TextBlock Text="Graphics Core Load" FontSize="11" Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,4"/>
                                        <Grid>
                                            <ProgressBar Style="{StaticResource ModernProgressBar}" Value="{Binding Diagnostics.GpuLoad}" Maximum="100" Foreground="{StaticResource BrushAccentPurple}"/>
                                        </Grid>
                                        <Grid Margin="0,4,0,12">
                                            <TextBlock Text="Core Activity" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding Diagnostics.GpuLoad, StringFormat={}{0:F1} %}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12"/>
                                        </Grid>

                                        <!-- GPU Temp -->
                                        <TextBlock Text="Graphics Core Temperature" FontSize="11" Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,4"/>
                                        <Grid>
                                            <ProgressBar Style="{StaticResource ModernProgressBar}" Value="{Binding Diagnostics.GpuTemp}" Maximum="100" Foreground="{StaticResource BrushDanger}"/>
                                        </Grid>
                                        <Grid Margin="0,4,0,12">
                                            <TextBlock Text="GPU Temperature" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding Diagnostics.GpuTemp, StringFormat={}{0:F1} °C}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12"/>
                                        </Grid>

                                        <!-- GPU VRAM -->
                                        <TextBlock Text="VRAM Load" FontSize="11" Foreground="{StaticResource BrushTextSecondary}" Margin="0,4,0,4"/>
                                        <Grid>
                                            <ProgressBar Style="{StaticResource ModernProgressBar}" Value="{Binding Diagnostics.GpuVramUsage}" Maximum="100"/>
                                        </Grid>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="VRAM Usage" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding Diagnostics.GpuVramUsage, StringFormat={}{0:F1} %}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Memory Overview Card -->
                                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="SYSTEM MEMORY (RAM)" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,12"/>

                                        <TextBlock Text="Physical RAM Load" FontSize="11" Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <ProgressBar Style="{StaticResource ModernProgressBar}" Value="{Binding Diagnostics.RamPercent}" Maximum="100" Foreground="{StaticResource BrushSuccess}"/>
                                        </Grid>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Diagnostics.RamUsageDisplay}" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding Diagnostics.RamPercent, StringFormat={}{0:F1} %}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Detailed CPU Core temperatures (Grid) -->
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="INDIVIDUAL CPU CORES MONITOR" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}" FontSize="13"/>
                                <TextBlock Grid.Row="1" Text="Low-level core sensors for temperature and load. Colors: Cold/Normal (Green), Warm (Orange), Hot (Red)." Style="{StaticResource TextMuted}" Margin="0,4,0,10"/>

                                <!-- Scrollable grid of CPU Cores -->
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Diagnostics.CpuCores}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3" VerticalAlignment="Top"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Border color dynamically bound to TemperatureColor -->
                                                <Border BorderBrush="{Binding TemperatureColor}" BorderThickness="1.5" Background="#0C0E14" CornerRadius="8" Padding="12" Margin="5" SnapsToDevicePixels="True">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        
                                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrushTextSecondary}" HorizontalAlignment="Center"/>
                                                        
                                                        <!-- Temperature displays in bound color -->
                                                        <TextBlock Grid.Row="1" Text="{Binding TemperatureDisplay}" FontSize="18" FontWeight="Bold" Foreground="{Binding TemperatureColor}" HorizontalAlignment="Center" Margin="0,6,0,4"/>
                                                        
                                                        <Grid Grid.Row="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Load:" FontSize="10" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center"/>
                                                            <ProgressBar Grid.Column="1" Style="{StaticResource ModernProgressBar}" Value="{Binding Load, TargetNullValue=0}" Maximum="100" Height="4" Margin="6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding LoadDisplay}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <!-- PAGE 1: BENCHMARK & TESTING TOOLS -->
                    <Grid Visibility="{Binding IsToolsSelected, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,16" Background="#0C0E14" BorderBrush="#1C1F2E">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="External Diagnostic &amp; Stress Tools" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrushAccentCyan}"/>
                                    <TextBlock Text="Executables will be scanned in removable USB drives automatically. Override manually if they reside locally." Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Rescan USB Sticks" Command="{Binding RefreshUsbCommand}" Padding="12,6" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Tools}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="280" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Left Side: Tool Information -->
                                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}"/>
                                                        
                                                        <!-- Status Tag -->
                                                        <Border CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#10EF4444"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFound}" Value="True">
                                                                            <Setter Property="Background" Value="#1010B981"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding DisplayStatus}" FontSize="10" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource BrushDanger}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFound}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource BrushSuccess}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource TextSubheader}" Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,6,0,10"/>
                                                    
                                                    <!-- Path description -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Executable Path: " FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Path, TargetNullValue='(Not resolved)'}" FontSize="11" Foreground="{StaticResource BrushTextSecondary}" TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </StackPanel>

                                                <!-- Right Side: Commands Panel -->
                                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Launch Button (spans 2 columns) -->
                                                    <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                                                            Style="{StaticResource PrimaryButton}" 
                                                            Content="LAUNCH BENCHMARK" 
                                                            Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding Key}"
                                                            IsEnabled="{Binding IsFound}"
                                                            Height="40" 
                                                            Margin="0,0,0,8"/>

                                                    <!-- Browse Override -->
                                                    <Button Grid.Row="1" Grid.Column="0" 
                                                            Style="{StaticResource ModernButton}" 
                                                            Content="Browse..." 
                                                            Command="{Binding DataContext.BrowseCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding Key}"
                                                            FontSize="11" 
                                                            Padding="0,8"
                                                            Margin="0,0,4,0"/>

                                                    <!-- Clear / Auto -->
                                                    <Button Grid.Row="1" Grid.Column="1" 
                                                            Style="{StaticResource ModernButton}" 
                                                            Content="Reset Auto" 
                                                            Command="{Binding DataContext.ClearPathCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding Key}"
                                                            FontSize="11" 
                                                            Padding="0,8"
                                                            Margin="4,0,0,0"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- PAGE 2: SYSTEM REPAIR -->
                    <Grid Visibility="{Binding IsRepairSelected, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,16" Background="#0C0E14" BorderBrush="#1C1F2E">
                            <StackPanel>
                                <TextBlock Text="Windows System Repair Utilities" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrushAccentCyan}"/>
                                <TextBlock Text="These built-in Windows diagnostics tools scan and repair file corruption, registry components, and system integrity." Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <UniformGrid Columns="2" VerticalAlignment="Top">
                                <!-- SFC Card -->
                                <Border Style="{StaticResource CardStyle}" Margin="5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="System File Checker (SFC)" FontSize="15" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}"/>
                                        <TextBlock Grid.Row="1" Text="Scans all protected system files and replaces corrupted files with a cached copy from the Windows Component Store. Extremely useful for resolving random crashes and system instability." Style="{StaticResource TextSubheader}" Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,8,0,16"/>
                                        <Button Grid.Row="2" Style="{StaticResource PrimaryButton}" Content="Run SFC Scan (sfc /scannow)" Command="{Binding RunRepairCommand}" CommandParameter="sfc" Height="38"/>
                                    </Grid>
                                </Border>

                                <!-- DISM Restore Health Card -->
                                <Border Style="{StaticResource CardStyle}" Margin="5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="DISM Restore Health" FontSize="15" FontWeight="Bold" Foreground="{StaticResource BrushAccentPurple}"/>
                                        <TextBlock Grid.Row="1" Text="Scans the Windows image for component store corruption and performs repair operations automatically by downloading replacement files from Windows Update. Fixes deep OS issues." Style="{StaticResource TextSubheader}" Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,8,0,16"/>
                                        <Button Grid.Row="2" Style="{StaticResource PrimaryButton}" Background="{StaticResource BrushAccentPurple}" Content="Run DISM Repair" Command="{Binding RunRepairCommand}" CommandParameter="dism_restore" Height="38">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                        <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="true">
                                                            <Setter TargetName="border" Property="Background" Value="#B572FF" />
                                                            <Setter TargetName="border" Property="Effect" Value="{StaticResource ShadowGlowPurple}" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="true">
                                                            <Setter TargetName="border" Property="Background" Value="#8F3BE6" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- DISM Check Health Card -->
                                <Border Style="{StaticResource CardStyle}" Margin="5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="DISM Check Health" FontSize="15" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}"/>
                                        <TextBlock Grid.Row="1" Text="Quickly checks whether the Windows component store image has been flagged as corrupted by a previous process. This is a read-only check that takes only a few seconds." Style="{StaticResource TextSubheader}" Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,8,0,16"/>
                                        <Button Grid.Row="2" Style="{StaticResource ModernButton}" Content="Run DISM Check" Command="{Binding RunRepairCommand}" CommandParameter="dism_check" Height="38"/>
                                    </Grid>
                                </Border>

                                <!-- Check Disk Card -->
                                <Border Style="{StaticResource CardStyle}" Margin="5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Check Disk (Chkdsk)" FontSize="15" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}"/>
                                        <TextBlock Grid.Row="1" Text="Scans the primary file system on drive C: for logical and physical disk errors. Runs in read-only mode to detect problems. Note: /f or /r repairs require a reboot." Style="{StaticResource TextSubheader}" Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,8,0,16"/>
                                        <Button Grid.Row="2" Style="{StaticResource ModernButton}" Content="Run Read-Only chkdsk" Command="{Binding RunRepairCommand}" CommandParameter="chkdsk" Height="38"/>
                                    </Grid>
                                </Border>
                            </UniformGrid>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- PAGE 3: SYSTEM GUIDE -->
                    <Grid Visibility="{Binding IsInfoSelected, Converter={StaticResource BoolToVis}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Stress-Testing and Diagnostics Guide" FontSize="16" FontWeight="Bold" Foreground="{StaticResource BrushAccentCyan}" Margin="0,0,0,10"/>
                                        <TextBlock Text="This utility is designed for system administrators, overclockers, and hardware technicians. By putting stress testing tools directly on a USB drive, you can run diagnostic tests on any PC quickly without installing bloatware." Style="{StaticResource TextSubheader}" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                        <Separator Background="#222636" Margin="0,0,0,15"/>

                                        <TextBlock Text="How to set up your USB stick:" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,6"/>
                                        <TextBlock Text="1. Insert your USB stick into the diagnostic computer." Foreground="{StaticResource BrushTextSecondary}" Margin="10,0,0,4"/>
                                        <TextBlock Text="2. Create the folders or place the executables in the root directories of the USB:" Foreground="{StaticResource BrushTextSecondary}" Margin="10,0,0,4"/>
                                        <BulletDecorator Margin="30,0,0,4">
                                            <BulletDecorator.Bullet>
                                                <Ellipse Width="4" Height="4" Fill="{StaticResource BrushAccentCyan}"/>
                                            </BulletDecorator.Bullet>
                                            <TextBlock Text=" OCCT: Place OCCT.exe or OCCTPersonal.exe" Foreground="{StaticResource BrushTextSecondary}" Margin="6,0,0,0"/>
                                        </BulletDecorator>
                                        <BulletDecorator Margin="30,0,0,4">
                                            <BulletDecorator.Bullet>
                                                <Ellipse Width="4" Height="4" Fill="{StaticResource BrushAccentCyan}"/>
                                            </BulletDecorator.Bullet>
                                            <TextBlock Text=" FurMark: Place FurMark.exe or FurMark2.exe" Foreground="{StaticResource BrushTextSecondary}" Margin="6,0,0,0"/>
                                        </BulletDecorator>
                                        <BulletDecorator Margin="30,0,0,4">
                                            <BulletDecorator.Bullet>
                                                <Ellipse Width="4" Height="4" Fill="{StaticResource BrushAccentCyan}"/>
                                            </BulletDecorator.Bullet>
                                            <TextBlock Text=" Prime95: Place prime95.exe" Foreground="{StaticResource BrushTextSecondary}" Margin="6,0,0,0"/>
                                        </BulletDecorator>
                                        <TextBlock Text="3. Click 'Scan Removable Drives' in the sidebar or 'Rescan' on the Tools page to auto-detect them." Foreground="{StaticResource BrushTextSecondary}" Margin="10,4,0,10"/>

                                        <TextBlock Text="Manual Override:" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource BrushTextPrimary}" Margin="0,10,0,6"/>
                                        <TextBlock Text="If you want to run the tools from a local folder instead of a USB stick, click 'Browse...' in the Tools tab and select the executable. The program will remember this path by writing it to tool_paths.txt in the application directory." Style="{StaticResource TextSubheader}" TextWrapping="Wrap" Margin="10,0,0,10"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Critical Hardware Thresholds" FontSize="15" FontWeight="Bold" Foreground="{StaticResource BrushAccentPurple}" Margin="0,0,0,10"/>
                                        
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="CPU Temp" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>
                                            <TextBlock Grid.Column="1" Text="&lt; 80 °C" Foreground="{StaticResource BrushSuccess}"/>
                                            <TextBlock Grid.Column="2" Text="Safe. Under load, modern CPUs run warm. &gt; 90°C might trigger thermal throttling." Style="{StaticResource TextMuted}"/>
                                        </Grid>

                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="GPU Temp" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>
                                            <TextBlock Grid.Column="1" Text="&lt; 83 °C" Foreground="{StaticResource BrushSuccess}"/>
                                            <TextBlock Grid.Column="2" Text="Typical target temperature for modern GPUs. Thermal limits usually trigger at 84-89°C." Style="{StaticResource TextMuted}"/>
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="RAM Load" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>
                                            <TextBlock Grid.Column="1" Text="&lt; 90 %" Foreground="{StaticResource BrushSuccess}"/>
                                            <TextBlock Grid.Column="2" Text="System performance degrades heavily if RAM reaches 95% due to pagefile swapping." Style="{StaticResource TextMuted}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- PAGE 4: BATTERY TEST -->
                    <Grid Visibility="{Binding IsBatteryTestSelected, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <!-- Left: Battery Status & Info -->
                            <ColumnDefinition Width="380" />
                            <!-- Right: Stress Test Control & Log -->
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Panel: Specs -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                            <StackPanel>
                                <!-- Battery Health Card -->
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="BATTERIE-GESUNDHEIT" FontWeight="Bold" Foreground="{StaticResource BrushSuccess}" FontSize="12" Margin="0,0,0,12"/>
                                        
                                        <!-- Big Health Display (Glassmorphism circle) -->
                                        <Grid Height="120" Width="120" HorizontalAlignment="Center" Margin="0,10,0,16">
                                            <Ellipse Stroke="#10131E" StrokeThickness="10" />
                                            <!-- Colored status indicator ring -->
                                            <Ellipse Stroke="{StaticResource BrushSuccess}" StrokeThickness="10" StrokeDashArray="10 2"/>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding BatteryInfo.HealthDisplay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource BrushTextPrimary}"/>
                                                <TextBlock Text="Gesundheit" FontSize="10" Foreground="{StaticResource BrushTextSecondary}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Rating Text -->
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Batterie Betriebsbereit" />
                                                    <Setter Property="Foreground" Value="{StaticResource BrushSuccess}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding BatteryInfo.IsPresent}" Value="False">
                                                            <Setter Property="Text" Value="Kein Akku erkannt" />
                                                            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <TextBlock Text="Ein Wert über 80% gilt als gut. Bei Werten darunter empfiehlt Windows einen Austausch." Style="{StaticResource TextMuted}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Battery Details Card -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="AKKU DETAILS" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,12"/>

                                        <Grid Margin="0,4">
                                            <TextBlock Text="Hersteller:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BatteryInfo.Manufacturer}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <TextBlock Text="Modellname:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BatteryInfo.DeviceName}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <TextBlock Text="Chemie:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BatteryInfo.Chemistry}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </Grid>
                                        
                                        <Separator Background="#222636" Margin="0,8"/>

                                        <Grid Margin="0,4">
                                            <TextBlock Text="Design-Kapazität:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BatteryInfo.DesignCapacityDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <TextBlock Text="Volle Ladekapazität:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BatteryInfo.FullChargeCapacityDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </Grid>

                                        <Separator Background="#222636" Margin="0,8"/>

                                        <Grid Margin="0,4">
                                            <TextBlock Text="Stromquelle:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Akku (Entladung)" />
                                                        <Setter Property="Foreground" Value="{StaticResource BrushWarning}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding BatteryInfo.IsConnectedToAc}" Value="True">
                                                                <Setter Property="Text" Value="Netzbetrieb (AC)" />
                                                                <Setter Property="Foreground" Value="{StaticResource BrushSuccess}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        
                                        <Grid Margin="0,4">
                                            <TextBlock Text="Ladestatus:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BatteryInfo.ChargingStatusDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <TextBlock Text="Aktuelle Ladung:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BatteryInfo.CurrentChargePercent, StringFormat={}{0:F0} %}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <TextBlock Text="Restlaufzeit:" Style="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BatteryInfo.RemainingTimeDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{StaticResource BrushAccentCyan}"/>
                                        </Grid>
                                        
                                        <!-- Charge Progress Bar -->
                                        <ProgressBar Style="{StaticResource ModernProgressBar}" Value="{Binding BatteryInfo.CurrentChargePercent}" Maximum="100" Foreground="{StaticResource BrushSuccess}" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Right Panel: Stress Test -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Stress Test Card -->
                            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="AKKU-ENTLADUNGSTEST (30 MINUTEN)" FontWeight="Bold" Foreground="{StaticResource BrushAccentCyan}" FontSize="12" Margin="0,0,0,8"/>
                                    <TextBlock Text="Dieser Test belastet die Hardware durch kontinuierliches Streaming eines YouTube-Testvideos im Hintergrund, um die reale Entladegeschwindigkeit zu ermitteln." Style="{StaticResource TextSubheader}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    
                                    <Border Background="#0C0E14" BorderBrush="#1C1F2E" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="YouTube Link:" FontWeight="SemiBold" Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Text=" https://www.youtube.com/watch?v=yq6c8h0Z3-Q" Foreground="{StaticResource BrushAccentCyan}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Test Controls -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Start Button (visible when not running) -->
                                        <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Content="Stresstest starten" 
                                                Command="{Binding StartBatteryTestCommand}" Height="40" 
                                                Visibility="{Binding IsNotBatteryTestRunning, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Cancel Button (visible when running) -->
                                        <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Content="Test abbrechen" 
                                                Command="{Binding StopBatteryTestCommand}" Height="40" Background="#EF4444"
                                                Visibility="{Binding IsBatteryTestRunning, Converter={StaticResource BoolToVis}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="true">
                                                            <Setter TargetName="border" Property="Background" Value="#F87171" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="true">
                                                            <Setter TargetName="border" Property="Background" Value="#DC2626" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- Countdown and Status Display -->
                                        <Border Grid.Column="1" Background="#0C0E14" BorderBrush="#1C1F2E" BorderThickness="1" CornerRadius="8" Padding="16,0" Margin="12,0,0,0" Height="40" VerticalAlignment="Center"
                                                Visibility="{Binding IsBatteryTestRunning, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Pulsing dot -->
                                                <Ellipse Width="8" Height="8" Fill="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBatteryTestRunning}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard Name="Pulse">
                                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.6"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="Restlaufzeit: " Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding BatteryTestRemainingDisplay}" Foreground="{StaticResource BrushTextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Results and Logs Tab Grid -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Completed Summary Result -->
                                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Background="#0D2E27" BorderBrush="#155E4C" BorderThickness="1" Margin="0,0,0,12"
                                        Visibility="{Binding BatteryTestCompleted, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="TEST BEENDET - ZUSAMMENFASSUNG" FontWeight="Bold" Foreground="{StaticResource BrushSuccess}" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding BatteryTestResults}" FontSize="12" Foreground="{StaticResource BrushTextPrimary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="PDF-Protokoll speichern" Command="{Binding SaveBatteryReportCommand}" VerticalAlignment="Center" Padding="12,10" Margin="16,0,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- Activity Log list -->
                                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="TESTVERLAUF" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                                        <ListBox Grid.Row="1" ItemsSource="{Binding BatteryTestLog}" Background="#0C0E14" BorderBrush="#1C1F2E" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="FontFamily" Value="Consolas, monospace"/>
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="Focusable" Value="False"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                    
                </Grid>

                <!-- ================= STATUS BAR ================= -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,12,0,0" Background="#0A0B10" BorderBrush="#1C1F2E">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <!-- Small indicator dot -->
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource BrushSuccess}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource BrushDanger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" VerticalAlignment="Center" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource BrushDanger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="Hardware Monitor Running" FontSize="11" Foreground="{StaticResource BrushTextMuted}" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
